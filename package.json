{
  "name": "deepforge",
  "version": "0.1.0",
  "description": "Generate structured wiki documentation for any code repository",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deepforge": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli/index.ts generate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wisecoders/deepforge.git"
  },
  "keywords": [
    "documentation",
    "wiki",
    "code-analysis",
    "knowledge-graph",
    "tree-sitter",
    "llm",
    "kubernetes",
    "docsify",
    "mermaid"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "dotenv": "^17.4.2",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.25.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
